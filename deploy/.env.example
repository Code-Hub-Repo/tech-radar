# Copy this file to deploy/.env and fill in real values for local/dev use.
# deploy/.env is gitignored (matched by the repo-wide ".env" pattern) — never commit real secrets.

# --- Database ---
DATABASE_URL=jdbc:postgresql://localhost:5432/techradar
POSTGRES_USER=techradar
POSTGRES_PASSWORD=change-me
DB_POOL_SIZE=10

# --- Admin auth ---
ADMIN_USERNAME=admin
# bcrypt hash of the admin password (at.favre.lib:bcrypt, cost factor 12) — never store the
# plaintext password anywhere.
ADMIN_PASSWORD_HASH=replace-with-a-real-bcrypt-hash

# --- JWT ---
# HS256 signing secret — must be at least 32 characters (256 bits). Generate with e.g.
# `openssl rand -base64 48`.
JWT_SECRET=replace-with-a-real-32-plus-character-secret

# --- Server ---
PORT=8080

# --- CORS ---
# Comma-separated list of allowed origins (scheme://host[:port]).
CORS_ALLOWED_ORIGINS=https://radar.codehub.gr,http://localhost:5173,http://localhost:4173
